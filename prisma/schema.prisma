generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String              @id @default(uuid())
  email           String              @unique
  username        String              @unique
  password        String              // bcrypt hashed
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Email verification
  isEmailVerified                 Boolean   @default(false)
  emailVerificationToken          String?   @unique
  emailVerificationTokenExpiresAt DateTime?

  // Password reset
  passwordResetToken          String?   @unique
  passwordResetTokenExpiresAt DateTime?

  // Relations
  authoredWorks   Work[]              @relation("AuthoredWorks")
  pages           Page[]
  collaborations  WorkCollaborator[]
  refreshTokens   RefreshToken[]
  likes           Like[]
}

model Work {
  id                  String              @id @default(uuid())
  type                String              @default("novel")  // "novel" or "comic" (future)
  genre               String?             // e.g. "fantasy", "sci-fi", "mystery", "romance", "horror", "historical-fiction", "thriller", "uncategorized"
  title               String
  description         String?
  authorId            String
  author              User                @relation("AuthoredWorks", fields: [authorId], references: [id])
  pageCharLimit       Int                 @default(2000)
  allowCollaboration  Boolean             @default(true)
  likesCount          Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relations
  pages               Page[]
  collaborators       WorkCollaborator[]
  likes               Like[]
}

model Page {
  id          String    @id @default(uuid())
  workId      String
  work        Work      @relation(fields: [workId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String    @db.Text
  pageNumber  Int?      // Nullable - only assigned when approved
  status      String    @default("pending") // "pending" | "approved"
  likesCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  approvedAt  DateTime? // Timestamp when approved
  likes       Like[]
  
  @@unique([workId, pageNumber])
  @@index([workId, status])
}

model WorkCollaborator {
  id         String   @id @default(uuid())
  workId     String
  work       Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  approvedAt DateTime @default(now())
  
  @@unique([workId, userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workId    String?
  work      Work?    @relation(fields: [workId], references: [id], onDelete: Cascade)
  pageId    String?
  page      Page?    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, workId])
  @@unique([userId, pageId])
  @@index([workId])
  @@index([pageId])
  @@index([userId])
}
